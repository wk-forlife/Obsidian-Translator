{
  "name": "obsidian-pdf-niutrans-auto-translator",
  "version": "0.1.0",
  "description": "Obsidian plugin for automatic PDF selection translation with NiuTrans.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
  },
