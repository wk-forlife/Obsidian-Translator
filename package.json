    "obsidian",
    "plugin",
    "pdf",
    "translation",
    "niutrans"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.17.30",
    "esbuild": "^0.25.2",
    "obsidian": "latest",
    "typescript": "^5.8.3"
  }
}
